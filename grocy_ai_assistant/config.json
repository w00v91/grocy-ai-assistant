{
  "name": "Grocy AI Assistant",
  "version": "5.1.8",
  "slug": "grocy_ai_assistant",
  "dependencies": ["a0d49513_grocy"],
  "description": "AI assistant for Grocy",
  "startup": "services",
  "boot": "auto",
  "init": false,
  "arch": [
    "amd64",
    "aarch64",
    "armv7"
  ],
  "map": ["config:rw"],
  "privileged": ["SYS_ADMIN"],
  "host_network": false,
  "ports": {
    "8000/tcp": 8000
  },
  "options": {
    "api_key": "DEIN_KI_KEY",
    "grocy_api_key": "DEIN_GROCY_KEY",
    "ollama_url": "http://76e18fb5_ollama:11434/api/generate",
    "ollama_model": "llama3",
    "debug_mode": false
  },
  "schema": {
    "api_key": "str",
    "grocy_api_key": "str",
    "ollama_url": "str",
    "ollama_model": "str",
    "debug_mode": "bool",
  }
}