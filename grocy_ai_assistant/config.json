{
  "name": "Grocy AI Assistant",
  "version": "7.1.90",
  "slug": "grocy_ai_assistant",
  "dependencies": [
    "a0d49513_grocy"
  ],
  "description": "AI assistant for Grocy",
  "startup": "services",
  "boot": "auto",
  "init": false,
  "arch": [
    "amd64",
    "aarch64",
    "armv7"
  ],
  "map": [
    "config:rw"
  ],
  "privileged": [
    "SYS_ADMIN"
  ],
  "host_network": false,
  "ingress": true,
  "ingress_port": 8000,
  "homeassistant_api": true,
  "hassio_api": true,
  "options": {
    "api_key": "DEIN_KI_KEY",
    "grocy_api_key": "DEIN_GROCY_KEY",
    "grocy_base_url": "http://homeassistant.local:9192/api",
    "ollama_url": "http://76e18fb5_ollama:11434/api/generate",
    "ollama_model": "llama3",
    "ollama_llava_model": "llava",
    "scanner_barcode_fallback_seconds": 5,
    "scanner_llava_min_confidence": 75,
    "scanner_llava_timeout_seconds": 45,
    "dashboard_polling_interval_seconds": 5,
    "notification_global_enabled": true,
    "image_generation_enabled": false,
    "openai_api_key": "DEIN_OPENAI_KEY",
    "openai_image_model": "gpt-image-1",
    "generate_missing_product_images_on_startup": false,
    "debug_mode": false
  },
  "schema": {
    "api_key": "str",
    "grocy_api_key": "str",
    "grocy_base_url": "str",
    "ollama_url": "str",
    "ollama_model": "str",
    "ollama_llava_model": "str",
    "scanner_barcode_fallback_seconds": "int(1,30)",
    "scanner_llava_min_confidence": "int(1,100)",
    "scanner_llava_timeout_seconds": "int(10,120)",
    "dashboard_polling_interval_seconds": "int(1,60)",
    "notification_global_enabled": "bool",
    "image_generation_enabled": "bool",
    "openai_api_key": "password",
    "openai_image_model": "str",
    "generate_missing_product_images_on_startup": "bool",
    "debug_mode": "bool"
  }
}
